---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

// Load all projects from the content collection, sorted by order field.
// To add a project: create a new .md file in src/content/projects/ — it appears here automatically.
const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects — Alternative Concept Technologies"
  description="Applied engineering tools across FEA, CFD, CAD, additive manufacturing, and immersive experiences."
>

  <!-- ===== PROJECTS HERO ===== -->
  <section class="projects-hero" aria-labelledby="projects-heading">
    <div class="container">
      <p class="eyebrow">Applied Engineering Tools</p>
      <h1 id="projects-heading">Projects</h1>
      <p>
        Applied engineering tools across FEA, CFD, CAD, additive manufacturing,
        and immersive experiences. More projects added as work progresses.
      </p>
    </div>
  </section>

  <!-- ===== PROJECT GRID ===== -->
  <!--
    Projects render from src/content/projects/*.md — no hardcoded card HTML here.
    Adding a project = adding one .md file. See README.md for instructions.
  -->
  <section class="section projects-grid-section" aria-label="Project catalogue">
    <div class="container">
      <ul class="projects-grid" role="list" aria-label="Engineering projects">
        {sortedProjects.map(project => (
          <li>
            <ProjectCard project={project} />
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>
