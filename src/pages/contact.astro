---
import BaseLayout from '../layouts/BaseLayout.astro';

// Contact email: andyr@campbell.us.com — Approved by Andy 2026-07-12.
// LinkedIn: linkedin.com/in/andyrcampbell — confirmed.
---

<BaseLayout
  title="Contact — Alternative Concept Technologies"
  description="Contact Andrew R. Campbell for engineering software projects, consulting, or collaboration enquiries."
>

  <section class="contact-page" aria-labelledby="contact-heading">
    <div class="container">

      <div class="contact-intro">
        <p class="eyebrow">Get in touch</p>
        <h1 id="contact-heading">Contact</h1>
        <p>
          For engineering software projects, consulting, or collaboration
          enquiries — reach out via email or LinkedIn.
        </p>
      </div>

      <div class="contact-links">

        <!-- Email — andyr@campbell.us.com approved by Andy 2026-07-12 -->
        <a
          href="mailto:andyr@campbell.us.com"
          class="contact-link-item"
          aria-label="Send email to andyr@campbell.us.com"
        >
          <svg
            class="contact-link-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20" height="20"
            viewBox="0 0 24 24"
            fill="none" stroke="currentColor"
            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m2 7 9.5 6.5a1 1 0 0 0 1 0L22 7"/>
          </svg>
          <div>
            <span class="contact-link-label">Email</span>
            <span class="contact-link-value">andyr@campbell.us.com</span>
          </div>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/andyrcampbell"
          class="contact-link-item"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Andrew Campbell on LinkedIn (opens in new tab)"
        >
          <svg
            class="contact-link-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20" height="20"
            viewBox="0 0 24 24"
            fill="none" stroke="currentColor"
            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          <div>
            <span class="contact-link-label">LinkedIn</span>
            <span class="contact-link-value">linkedin.com/in/andyrcampbell</span>
          </div>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
